{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SuperFan",
  "version": "1.0.0",
  "identifier": "com.superfan.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "scripts/stage-fan-actuation-daemon.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "SuperFan",
        "label": "main",
        "width": 400,
        "height": 620,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist",
      "minimumSystemVersion": "13.0",
      "files": {
        "Library/LaunchDaemons/com.superfan.fan-actuation.plist": "bundle/macos/LaunchDaemons/com.superfan.fan-actuation.plist",
        "Resources/fan-actuation-daemon": "bundle/macos/resources/fan-actuation-daemon"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
